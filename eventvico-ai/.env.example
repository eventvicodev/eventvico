# Eventvico AI Service — environment variables
# Copy to .env and fill in values before running locally

# Shared secret between Next.js app and this service
# Must match FASTAPI_SERVICE_KEY in the Next.js .env
FASTAPI_SERVICE_KEY=change-me-in-production

# Groq API key for LLM-powered recipe generation
GROQ_API_KEY=

# Supabase connection (for reading/writing job results)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: path to a custom YOLO model weights file
# Defaults to yolov8n.pt (auto-downloaded on first run)
YOLO_MODEL_PATH=yolov8n.pt
